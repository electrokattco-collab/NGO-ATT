# =============================================================================
# ATT NGO Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env or any private service account data to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# Firebase Configuration
# -----------------------------------------------------------------------------
# Client-side Firebase config (public)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_DATABASE_ID=your-database-id

# Server-side Firebase Admin SDK (private)
# Paste the full JSON content as a single line, or use application default credentials.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@your-project-id.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/..."}

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
SESSION_SECRET=replace-with-a-32-character-or-longer-secret
CORS_ORIGIN=https://your-production-domain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
PAYMENT_RATE_LIMIT_WINDOW_MS=3600000
PAYMENT_RATE_LIMIT_MAX_REQUESTS=10
CONTACT_RATE_LIMIT_WINDOW_MS=900000
CONTACT_RATE_LIMIT_MAX_REQUESTS=10

# -----------------------------------------------------------------------------
# Payment Gateway Configuration
# -----------------------------------------------------------------------------
# Yoco Configuration
YOCO_SECRET_KEY=sk_test_... or sk_live_...
YOCO_PUBLIC_KEY=pk_test_... or pk_live_...
YOCO_WEBHOOK_SECRET=your-yoco-webhook-secret

# PayFast Configuration
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase
PAYFAST_SANDBOX_MODE=true

# -----------------------------------------------------------------------------
# Email Service Configuration
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=SG.xxx...
EMAIL_FROM=noreply@attngo.org
EMAIL_FROM_NAME="ATT NGO"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# -----------------------------------------------------------------------------
# Monitoring & Logging
# -----------------------------------------------------------------------------
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
LOG_AGGREGATOR_URL=https://your-log-aggregator.example.com/v1/logs
LOG_AGGREGATOR_API_KEY=your-aggregator-api-key
LOG_LEVEL=info
VIRUS_SCAN_ENABLED=false

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_PAYMENTS=false
ENABLE_EMAILS=false
ENABLE_ANALYTICS=false
