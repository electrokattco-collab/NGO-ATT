# =============================================================================
# ATT NGO Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# Firebase Configuration
# -----------------------------------------------------------------------------
# Client-side Firebase config (public - matches firebase-applet-config.json)
VITE_FIREBASE_API_KEY=AIzaSyDma136xstx4efrwJHHtECirwTeWKlZ5JU
VITE_FIREBASE_AUTH_DOMAIN=gen-lang-client-0079941199.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=gen-lang-client-0079941199
VITE_FIREBASE_STORAGE_BUCKET=gen-lang-client-0079941199.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=199394900098
VITE_FIREBASE_APP_ID=1:199394900098:web:4938acfa7374aebe7f9c9b
VITE_FIREBASE_DATABASE_ID=ai-studio-1d72e57f-bfe5-418e-84a1-545fe3eb3ddb

# Server-side Firebase Admin SDK (private - service account JSON)
# Get this from Firebase Console > Project Settings > Service Accounts > Generate new private key
# Paste the entire JSON content here as a single line
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"gen-lang-client-0079941199",...}

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# Generate a strong random string (e.g., using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
SESSION_SECRET=your-super-secret-session-key-change-in-production

# CORS allowed origins (comma-separated for multiple)
# Example: https://yourdomain.com,https://admin.yourdomain.com
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Payment Gateway Configuration (Production)
# -----------------------------------------------------------------------------
# Yoco Configuration
YOCO_SECRET_KEY=sk_test_... or sk_live_...
YOCO_PUBLIC_KEY=pk_test_... or pk_live_...
YOCO_WEBHOOK_SECRET=whsec_...

# PayFast Configuration
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase
PAYFAST_SANDBOX_MODE=true

# -----------------------------------------------------------------------------
# Email Service Configuration
# -----------------------------------------------------------------------------
# SendGrid
SENDGRID_API_KEY=SG.xxx...
EMAIL_FROM=noreply@attngo.org
EMAIL_FROM_NAME="ATT NGO"

# OR SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# -----------------------------------------------------------------------------
# Monitoring & Logging
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking (optional)
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_PAYMENTS=false
ENABLE_EMAILS=false
ENABLE_ANALYTICS=false
